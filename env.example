# Base de données PostgreSQL (Scaleway ou autre)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Sécurité sessions (chaîne aléatoire longue)
SESSION_SECRET=changez-cette-valeur-par-une-chaine-aleatoire-longue

# Mot de passe super administrateur (VOUS)
SUPER_ADMIN_PASSWORD=changez-ce-mot-de-passe

# Clé API Anthropic globale (optionnel — peut être définie par client)
ANTHROPIC_API_KEY=sk-ant-api-votre-cle

# Environnement
NODE_ENV=production
PORT=3000
